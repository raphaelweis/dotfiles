#!/bin/bash

# Get the battery level as a percentage, and the battery status as a string
battery_level=$(cat /sys/class/power_supply/BAT0/capacity)
charging_status=$(cat /sys/class/power_supply/BAT0/status)

# Define the battery icon based on the battery level, and the battery status
battery_icon=""

if [ "$charging_status" == "Charging" ]; then
  case $battery_level in
     [0-9]|10) battery_icon="σΑΔü" ;;
    1[1-9]|20) battery_icon="σΑΔ€" ;;
    2[1-9]|30) battery_icon="σΑ²Ü" ;;
    3[1-9]|40) battery_icon="σΑ²΅" ;;
    4[1-9]|50) battery_icon="σΑ²à" ;;
    5[1-9]|60) battery_icon="σΑΔù" ;;
    6[1-9]|70) battery_icon="σΑ²â" ;;
    7[1-9]|80) battery_icon="σΑΔû" ;;
    8[1-9]|90) battery_icon="σΑ²ä" ;;
    9[1-9]   ) battery_icon="σΑ²΄" ;;
          100) battery_icon="σΑ²Ö" ;;
  esac
else
  case $battery_level in
     [0-9]|10) battery_icon="σΑ²É" ;;
    1[1-9]|20) battery_icon="σΑ¹Κ" ;;
    2[1-9]|30) battery_icon="σΑ¹Μ" ;;
    3[1-9]|40) battery_icon="σΑ¹Φ" ;;
    4[1-9]|50) battery_icon="σΑ¹Ϋ" ;;
    5[1-9]|60) battery_icon="σΑ¹Ψ" ;;
    6[1-9]|70) battery_icon="σΑ¹Ω" ;;
    7[1-9]|80) battery_icon="σΑ²Ä" ;;
    8[1-9]|90) battery_icon="σΑ²¹" ;;
    9[1-9]   ) battery_icon="σΑ²²" ;;
          100) battery_icon="σΑ¹Ι" ;;
  esac
fi

# Output the battery icon and percentage
echo "$battery_icon $battery_level%"
